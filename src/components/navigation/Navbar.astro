---
// Navbar — minimal site navigation
import Container from "../ui/Container.astro";
---

<nav class="navbar">
  <Container size="page">
    <div class="navbar-inner">
      <a href="/" class="navbar-brand">Gabriel Nieves</a>
      <div class="navbar-right">
        <ul class="navbar-links">
          <li><a href="/blog">Blog</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/resume">Resume</a></li>
        </ul>
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Toggle theme"
          title="Toggle dark mode"
        >
          <span class="toggle-track">
            <span class="toggle-thumb">
              <!-- Sun icon (shown in thumb when in light mode) -->
              <svg
                class="toggle-icon sun"
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              ><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line
                  x1="12"
                  y1="21"
                  x2="12"
                  y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line
                  x1="18.36"
                  y1="18.36"
                  x2="19.78"
                  y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line
                  x1="21"
                  y1="12"
                  x2="23"
                  y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line
                  x1="18.36"
                  y1="5.64"
                  x2="19.78"
                  y2="4.22" /></svg
              ><!-- Moon icon (shown in thumb when in dark mode) -->
              <svg
                class="toggle-icon moon"
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="currentColor"
                stroke="none"
              ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
            </span>
          </span>
        </button>
      </div>
    </div>
  </Container>
</nav>

<script>
  const btn = document.getElementById("theme-toggle");
  if (btn) {
    btn.addEventListener("click", () => {
      const html = document.documentElement;
      const current = html.dataset.theme;
      const next = current === "dark" ? "light" : "dark";
      html.dataset.theme = next;
      localStorage.setItem("theme", next);
    });
  }
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-background);
    border-bottom: var(--border-width-thin) solid var(--color-border);
    padding: var(--space-md) 0;
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar-brand {
    font-family: var(--font-serif);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    letter-spacing: var(--letter-spacing-tight);
    transition: color var(--transition-fast);
  }

  .navbar-brand:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .navbar-links {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .navbar-links a {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .navbar-links a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  /* ── Theme toggle (iOS-style) ──────────────────────────────────────────── */
  .navbar-right {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    border-radius: var(--radius-full);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .toggle-track {
    position: relative;
    display: flex;
    align-items: center;
    width: 44px;
    height: 24px;
    border-radius: var(--radius-full);
    background: var(--color-text-tertiary);
    transition: background var(--transition-normal);
  }

  :global([data-theme="dark"]) .toggle-track {
    background: var(--color-primary-muted);
  }

  .toggle-thumb {
    position: absolute;
    left: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-normal), background var(--transition-normal);
  }

  :global([data-theme="dark"]) .toggle-thumb {
    transform: translateX(20px);
  }

  .toggle-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .toggle-icon.sun {
    color: var(--color-warning);
  }

  .toggle-icon.moon {
    color: var(--color-accent);
  }

  /* Show sun icon in light mode, moon icon in dark mode */
  .toggle-icon.moon {
    display: none;
  }
  :global([data-theme="dark"]) .toggle-icon.sun {
    display: none;
  }
  :global([data-theme="dark"]) .toggle-icon.moon {
    display: flex;
  }
</style>