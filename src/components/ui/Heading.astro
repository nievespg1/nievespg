---
// Heading — semantic heading with configurable level
export interface Props {
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  class?: string;
}
const { level = 2, class: className } = Astro.props;
const classes = `heading heading--${level} ${className ?? ""}`.trim();
---

{
  level === 1 && <h1 class={classes}><slot /></h1>
}
{
  level === 2 && <h2 class={classes}><slot /></h2>
}
{
  level === 3 && <h3 class={classes}><slot /></h3>
}
{
  level === 4 && <h4 class={classes}><slot /></h4>
}
{
  level === 5 && <h5 class={classes}><slot /></h5>
}
{
  level === 6 && <h6 class={classes}><slot /></h6>
}

<style>
  .heading {
    font-family: var(--font-serif);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-text);
  }

  .heading--1 {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--space-lg);
  }

  .heading--2 {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-md);
  }

  .heading--3 {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-md);
  }

  .heading--4 {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-sm);
  }

  .heading--5 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-sm);
  }

  .heading--6 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-sm);
  }
</style>