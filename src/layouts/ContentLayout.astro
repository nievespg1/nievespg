---
// ContentLayout — page shell with navigation and footer
// Extends BaseLayout, adds Navbar + Footer + page container
import BaseLayout from "./BaseLayout.astro";
import Navbar from "../components/navigation/Navbar.astro";
import Footer from "../components/navigation/Footer.astro";
export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}
const props = Astro.props;
---

<BaseLayout {...props}>
  <Navbar />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>